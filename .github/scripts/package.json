    "bun": "^1.3.6",
    "octokit": "^5.0.5",
    "semver": "^7.7.4",
    "yaml": "^2.8.2",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.6",
    "@types/semver": "^7.7.1",
    "eslint": "^9.39.2",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-react": "^7.37.5",
